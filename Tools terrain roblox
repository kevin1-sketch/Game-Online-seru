local function buildScript()
    if #hist==0 then return "-- Belum ada ops." end
    local L={"local t=workspace.Terrain","local ops={"}
    for _,o in ipairs(hist) do
        L[#L+1]=string.format('  {%d,%d,%d,%d,%d,"%s","%s"},',o[1],o[2],o[3],o[4],o[5],o[6],o[7])
    end
    L[#L+1]="}"
    L[#L+1]="for _,o in ipairs(ops) do"
    L[#L+1]="  local pos=Vector3.new(o[1],o[2],o[3])"
    L[#L+1]="  local m=Enum.Material[o[6]] or Enum.Material.Grass"
    L[#L+1]="  if o[7]=='Ball' then t:FillBall(pos,o[4],m)"
    L[#L+1]="  elseif o[7]=='Box' then t:FillBlock(CFrame.new(pos),Vector3.new(o[4],o[5],o[4])*2,m)"
    L[#L+1]="  elseif o[7]=='Cylinder' then t:FillCylinder(CFrame.new(pos),o[5]*2,o[4],m) end"
    L[#L+1]="end"
    return table.concat(L,"\n")
end


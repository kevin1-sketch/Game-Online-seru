local function makeAnchor(part)
    local a = Instance.new("Attachment")
    a.Position = Vector3.new(0,0,0)
    a.Parent = part
    return a
end

local function spawnRope(posA, posB, partA, partB)
    local thick = getRopeThick() * 0.1
    local dist  = (posA - posB).Magnitude
    local slack = getRopeLen()
    local len   = dist + slack

    local attA = makeAnchor(partA)
    local attB = makeAnchor(partB)

    local rope = Instance.new("RopeConstraint")
    rope.Attachment0 = attA
    rope.Attachment1 = attB
    rope.Length      = len
    rope.Thickness   = thick
    rope.Restitution = 0
    rope.Visible     = true
    rope.Color       = BrickColor.new("Reddish brown")
    rope.Parent      = partA

    table.insert(allRopes, {rope, attA, attB})

    ropeStatusL.Text = "Dibuat! L="..math.floor(len)
    ropeStepL.Text   = "Total: "..#allRopes
    task.delay(2, function()
        if ropeOn then
            ropeStatusL.Text = "Tap Part A"
            ropeStepL.Text   = "Total: "..#allRopes
        end
    end)
end

local function getRayHitPart(xy)
    local ray=cam:ScreenPointToRay(xy.X,xy.Y)
    local rp=RaycastParams.new()
    rp.FilterType=Enum.RaycastFilterType.Exclude
    local char=player.Character
    if char then rp.FilterDescendantsInstances={char} end
    return workspace:Raycast(ray.Origin,ray.Direction*1000,rp)
end


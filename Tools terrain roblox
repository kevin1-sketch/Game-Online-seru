local function mkSlider(p,y,mn,mx,def,lbl)
    local tr=Instance.new("Frame")
    tr.Size=UDim2.new(1,-12,0,11);tr.Position=UDim2.new(0,6,0,y)
    tr.BackgroundColor3=Color3.fromRGB(35,35,45);tr.BorderSizePixel=0;tr.Parent=p;corner(tr,5)
    local fi=Instance.new("Frame")
    fi.Size=UDim2.new((def-mn)/(mx-mn),0,1,0)
    fi.BackgroundColor3=C1;fi.BorderSizePixel=0;fi.Parent=tr;corner(fi,5)
    local kn=Instance.new("Frame")
    kn.Size=UDim2.new(0,14,0,14);kn.AnchorPoint=Vector2.new(0.5,0.5)
    kn.Position=UDim2.new((def-mn)/(mx-mn),0,0.5,0)
    kn.BackgroundColor3=W;kn.BorderSizePixel=0;kn.Parent=tr;corner(kn,99)
    local drag,cur=false,def
    local function upd(pos)
        local rel=math.clamp((pos.X-tr.AbsolutePosition.X)/tr.AbsoluteSize.X,0,1)
        cur=math.floor(mn+rel*(mx-mn))
        fi.Size=UDim2.new(rel,0,1,0);kn.Position=UDim2.new(rel,0,0.5,0)
        if lbl then lbl.Text=lbl.Name..": "..cur end
    end
    tr.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then drag=true;upd(i.Position) end
    end)
    UIS.InputChanged:Connect(function(i)
        if drag and(i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then upd(i.Position) end
    end)
    UIS.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then drag=false end
    end)
    return function() return cur end
end


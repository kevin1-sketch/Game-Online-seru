local lastT=0
local function doFill(sp,r,st,mat)
    local sh=Shapes[selS][1]
    if sh=="Ball" then ter:FillBall(sp,r,mat)
    elseif sh=="Box" then ter:FillBlock(CFrame.new(sp),Vector3.new(r,st,r)*2,mat)
    elseif sh=="Cylinder" then ter:FillCylinder(CFrame.new(sp),st*2,r,mat) end
end

local function doPaint(xy)
    local now=tick();if now-lastT<0.06 then return end;lastT=now
    local ray=cam:ScreenPointToRay(xy.X,xy.Y)
    local rp=RaycastParams.new()
    rp.FilterType=Enum.RaycastFilterType.Exclude
    rp.FilterDescendantsInstances={player.Character or workspace}
    local hit=workspace:Raycast(ray.Origin,ray.Direction*1500,rp)
    if not hit then return end
    local sn=4;local pos=hit.Position
    local sp=Vector3.new(math.floor(pos.X/sn)*sn,math.floor(pos.Y/sn)*sn,math.floor(pos.Z/sn)*sn)
    local r=getBS();local st=getBST()
    local mat=eraseOn and Enum.Material.Air or Biomes[selB][2]
    doFill(sp,r,st,mat)
    if #hist<MAX then
        local mn=eraseOn and "Air" or (tostring(Biomes[selB][2]):match("%.(%w+)$") or "Grass")
        table.insert(hist,{sp.X,sp.Y,sp.Z,r,st,mn,Shapes[selS][1]})
        cntL.Text="Ops: "..#hist.."/"..MAX
        opsL.Text="Ops: "..#hist
    else
        cntL.Text="MAX! Clear dulu"
    end
end

UIS.InputBegan:Connect(function(i,gp)
    if gp then return end
    local isMouse=i.UserInputType==Enum.UserInputType.MouseButton1
    local isTouch=i.UserInputType==Enum.UserInputType.Touch
    if not(isMouse or isTouch) then return end

    local xy=Vector2.new(i.Position.X,i.Position.Y)

    if ropeOn then
        if ropeDebounce then return end
        ropeDebounce=true
        task.delay(0.3, function() ropeDebounce=false end)

        local hit=getRayHitPart(xy)
        if hit and hit.Instance and hit.Instance:IsA("BasePart") then
            if ropeStep==0 then
                ropeA=hit.Instance
                ropeAPos=hit.Position
                ropeStep=1
                ropeStatusL.Text="Titik A OK, tap B"
                ropeStepL.Text="Step: 2/2"
            elseif ropeStep==1 then
                ropeB=hit.Instance
                local posB=hit.Position
                spawnRope(ropeAPos, posB, ropeA, ropeB)
                ropeStep=0
                ropeStepL.Text="Step: 1/2"
                ropeStatusL.Text="Tap Part A"
            end
        else
            ropeStatusL.Text="Tap BasePart!"
        end
        return
    end

    if not paintOn then return end
    painting=true;touchXY=xy
end)

UIS.InputChanged:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch then

                'BRICKING CPU...',
                'MELTING GPU...',
                'EXPLODING HDD...'
            ];

            const alert = document.createElement('div');
            alert.className = 'alert-extreme';
            alert.style.top = Math.random() * 60 + 10 + '%';
            alert.style.left = Math.random() * 60 + 10 + '%';
            alert.innerHTML = `
                <div class="alert-title" style="font-size: 40px; color: #ff0000; margin-bottom: 20px;">⚠️ CRITICAL ALERT</div>
                <div class="alert-icon" style="font-size: 100px; text-align: center;">💀</div>                <div style="font-size: 28px; text-align: center; font-weight: bold;">
                    ${alerts[Math.floor(Math.random() * alerts.length)]}<br>
                    ${Math.floor(Math.random() * 100)}%
                </div>
            `;
            document.body.appendChild(alert);

            setTimeout(() => alert.remove(), 3000);
        }

        function startWarnings() {
            setInterval(() => {
                createSpinningWarning();
            }, 2000);
        }

        function createSpinningWarning() {
            const warning = document.createElement('div');
            warning.className = 'spin-warning';
            warning.style.top = Math.random() * 70 + 10 + '%';
            warning.style.left = Math.random() * 70 + 10 + '%';
            warning.innerHTML = '⚠️ WARNING';
            document.body.appendChild(warning);

            setTimeout(() => warning.remove(), 5000);
        }

        function startScrollingText() {
            const texts = [
                'CRITICAL ERROR: System failure imminent... ',
                'WARNING: All files being deleted... ',
                'ALERT: Hard drive corrupted... ',
                'ERROR: BIOS destroyed... ',
                'FATAL: System cannot recover... ',
                'DELETING: C:\\Windows\\System32... ',
                'FORMATTING: Drive C:... ',
                'ERASING: All partitions... ',
                'DESTROYING: Master Boot Record... ',
                'BRICKING: Hardware... '
            ];

            document.getElementById('errorScroll').textContent = texts.join('');
        }

        function startCountdown() {
            let seconds = 0;
            setInterval(() => {
                seconds++;
                const mins = Math.floor(seconds / 60).toString().padStart(2, '0');
                const secs = (seconds % 60).toString().padStart(2, '0');                document.getElementById('countdownExtreme').textContent = `${mins}:${secs}`;
            }, 1000);
        }

        function playAllSounds() {
            document.getElementById('sound1').play();
            setTimeout(() => document.getElementById('sound2').play(), 1000);
            setTimeout(() => document.getElementById('sound3').play(), 2000);
            
            setInterval(() => {
                document.getElementById('beep').play();
            }, 500);
        }

        function startFlashing() {
            document.getElementById('flashOverlay').classList.add('flash-active');
        }

        function createCursorClones() {
            for (let i = 0; i < 10; i++) {
                setTimeout(() => {
                    const clone = document.createElement('div');
                    clone.className = 'cursor-clone';
                    document.body.appendChild(clone);

                    setInterval(() => {
                        clone.style.left = Math.random() * window.innerWidth + 'px';
                        clone.style.top = Math.random() * window.innerHeight + 'px';
                    }, 200);
                }, i * 500);
            }
        }

        function createScreenTears() {
            setInterval(() => {
                const tear = document.createElement('div');
                tear.className = 'screen-tear';
                tear.style.left = Math.random() * 100 + '%';
                tear.style.animationDuration = (Math.random() * 0.5 + 0.3) + 's';
                document.body.appendChild(tear);

                setTimeout(() => tear.remove(), 1000);
            }, 300);
        }

        function startBlackScreenText() {
            const lines = [
                '> Initializing system destruction...',
                '> Bypassing security...', SUCCESS',
                '> Accessing root directory...', GRANTED',                '> Deleting critical files...',
                '> Removing System32...', ' + Math.floor(Math.random() * 100) + '%',
                '> Corrupting bootloader...',
                '> Erasing BIOS...',
                '> Destroying MBR...',
                '> Wiping partition table...',
                '> Bricking hardware...',
                '> SYSTEM DESTROYED',
                '> NO RECOVERY POSSIBLE',
                '> GAME OVER'
            ];

            let lineIndex = 0;
            const container = document.getElementById('blackScreenText');
            
            const interval = setInterval(() => {
                if (lineIndex >= lines.length) {
                    clearInterval(interval);
                    return;
                }
                
                const line = document.createElement('div');
                line.textContent = lines[lineIndex];
                line.style.marginBottom = '10px';
                line.style.color = lineIndex > lines.length - 3 ? '#ff0000' : '#0f0';
                container.appendChild(line);
                
                document.getElementById('beep').play();
                lineIndex++;
            }, 800);
        }

        function createRansomNotes() {
            setInterval(() => {
                const ransom = document.createElement('div');
                ransom.className = 'ransom-note';
                ransom.style.top = Math.random() * 50 + 10 + '%';
                ransom.style.left = Math.random() * 50 + 10 + '%';
                ransom.innerHTML = `
                    <div style="font-size: 48px; color: #ff0000; text-align: center; margin-bottom: 30px; font-weight: bold;">
                        💰 RANSOMWARE 💰
                    </div>
                    <div style="text-align: center;">
                        All your files have been encrypted!<br><br>
                        Pay <strong>Rp 1.000.000.000</strong> in Bitcoin<br>
                        to decrypt your files!<br><br>
                        <span style="color: #ff0000; font-size: 24px;">
                            You have 24 hours!<br>
                            After that, all files will be deleted forever!
                        </span>                    </div>
                    <div style="margin-top: 30px; text-align: center; font-size: 24px;">
                        Bitcoin Address:<br>
                        <strong>1ABC123XYZ789DEF456</strong>
                    </div>
                `;
                document.body.appendChild(ransom);

                setTimeout(() => ransom.remove(), 10000);
            }, 5000);
        }

        // Prevent everything
        window.onbeforeunload = function() {
            return "⚠️ CRITICAL ERROR: System destruction in progress! Do not close!";
        };

        document.addEventListener('contextmenu', e => e.preventDefault());

        document.addEventListener('keydown', function(e) {
            if (e.key === 'F12' || 
                (e.ctrlKey && e.shiftKey && e.key === 'I') ||
                (e.ctrlKey && e.key === 'U') ||
                e.key === 'Escape' ||
                e.key === 'F11' ||
                e.key === 'F5') {
                e.preventDefault();
                createExtremeAlert();
            }
        });

        // Disable right click
        document.onmousedown = function(e) {
            if (e.button === 2) {
                createExtremePopup('RIGHT CLICK DISABLED!');
                return false;
            }
        };
    </script>
</body>
